{
  "name": "meal-prep-planner",
  "version": "0.1.0",
  "private": true,
  "description": "Meal Prep Planner app for Claude + Google Drive + Instacart",
  "main": "dist/main/electron.js",
  "scripts": {
    "build": "npm run type-check && npm run build-main && npm run build-renderer",
    "build-main": "tsc --project tsconfig.json --outDir dist",
    "build-renderer": "vite build",
    "type-check": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "start": "npm run build && electron dist/main/electron.js",
    "dev": "concurrently --kill-others-on-fail \"npm run dev-renderer\" \"npm run dev-main\" \"npm run dev-electron\"",
    "dev-main": "tsc --project tsconfig.json --watch --outDir dist",
    "dev-renderer": "vite",
    "dev-electron": "sleep 3 && electron dist/main/electron.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.9",
    "@types/express": "^5.0.6",
    "electron-store": "^10.0.0",
    "express": "^5.2.1",
    "googleapis": "^131.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^9.0.0",
    "xlsx": "^0.18.5",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^30.0.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.2"
  }
}
